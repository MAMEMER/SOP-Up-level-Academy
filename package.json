{
  "name": "sop-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NEXT_TEST_WASM=1 NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next dev --webpack",
    "build": "NEXT_TEST_WASM=1 NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next build --webpack",
    "build:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
